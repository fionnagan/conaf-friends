# ─────────────────────────────────────────────────────────────────
# I Feel... Community Layer (Supabase)
# ─────────────────────────────────────────────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Run supabase-setup.sql in the SQL editor
# 3. Copy your project URL and keys below
# 4. Add these same vars to Vercel → Settings → Environment Variables

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────────────────
# PNG Storage (optional — only needed for permanent card storage)
# ─────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here
